{
  "name": "annoscr",
  "version": "1.0.1",
  "private": true,
  "description": "Annotation tool for GNOME (GJS + GTK4 + Libadwaita).",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "configure": "if [ -f build-aux/xgettext.ini ]; then meson setup build --native-file build-aux/xgettext.ini; else meson setup build; fi",
    "compile": "tsc -p .",
    "build": "meson compile -C build",
    "regenerate-languages": "meson compile -C build annoscr-pot",
    "lint": "eslint .",
    "lint:deb": "sh build-aux/lint-deb.sh",
    "format": "prettier -w .",
    "set-version": "sh build-aux/set-version.sh",
    "dist": "sh build-aux/dist.sh",
    "sign": "sh build-aux/sign.sh",
    "clean": "sh build-aux/clean.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@girs/adw-1": "^1.10.0-4.0.4",
    "@girs/cairo-1.0": "^1.0.0-4.0.4",
    "@girs/gdk-4.0": "^4.0.0-4.0.4",
    "@girs/gdkpixbuf-2.0": "^2.0.0-4.0.4",
    "@girs/gio-2.0": "^2.88.0-4.0.4",
    "@girs/gjs": "^4.0.4",
    "@girs/glib-2.0": "^2.88.0-4.0.4",
    "@girs/gobject-2.0": "^2.88.0-4.0.4",
    "@girs/graphene-1.0": "^1.0.0-4.0.4",
    "@girs/pango-1.0": "^1.57.1-4.0.4",
    "@girs/pangocairo-1.0": "^1.0.0-4.0.4",
    "@girs/xdp-1.0": "^1.0.0-4.0.4",
    "eslint": "^10.4.1",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
