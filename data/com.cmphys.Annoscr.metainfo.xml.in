<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application" xmlns:its="http://www.w3.org/2005/11/its" its:version="2.0">
  <id>com.cmphys.Annoscr</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Annoscr</name>
  <summary>Annotate screenshots</summary>

  <description>
    <p>
      Annoscr is a lightweight screenshot annotation tool for GNOME.
      Add arrows, text, shapes, highlighter strokes, and numbered stamps
      to images. Rotate or resize as needed, then export or copy to clipboard.
    </p>
  </description>

  <launchable type="desktop-id">com.cmphys.Annoscr.desktop</launchable>

  <url type="homepage">https://github.com/mdmower/annoscr</url>

  <provides>
    <binary>annoscr</binary>
    <mediatype>application/x-annoscr</mediatype>
  </provides>

  <developer id="com.cmphys">
    <name>Matt Mower</name>
  </developer>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="1.2.1" date="2026-06-30">
      <description its:translate="no">
        <ul>
          <li>The text placement editor now scales with the zoom level, so placing text on a zoomed-out image no longer opens an oversized card, and the box-text editor centers on its shape instead of spilling to one side.</li>
          <li>Cancelling a screenshot capture started from the command line with no instance already running now exits cleanly instead of leaving an empty window open.</li>
        </ul>
      </description>
    </release>
    <release version="1.2.0" date="2026-06-22">
      <description its:translate="no">
        <ul>
          <li>Right-click and drag pans the canvas with any tool, and the arrow keys pan when nothing is selected.</li>
          <li>Drag a box across empty canvas to select every annotation fully inside it; Ctrl+A selects all and Esc clears the selection.</li>
          <li>A rubber-band selection or a selection move auto-scrolls the canvas at a viewport edge, reaching areas outside the visible region.</li>
          <li>Opening and dismissing the color picker no longer flattens a mixed-color multi-selection.</li>
        </ul>
      </description>
    </release>
    <release version="1.1.0" date="2026-06-17">
      <description its:translate="no">
        <ul>
          <li>New preferences can close the window automatically after a save or copy, and a silent-save option writes images straight to the default folder without a dialog.</li>
          <li>When the window auto-closes, a system notification appears with a thumbnail; click it to reopen the saved file or re-paste the copied image, or use "Show in Files" to reveal a saved image.</li>
          <li>Images now respect their EXIF orientation when loaded, so photos from phones and cameras appear upright.</li>
          <li>An arrowhead no longer overshoots the shaft on very short arrows.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.3" date="2026-06-14">
      <description its:translate="no">
        <ul>
          <li>The window remembers its size and maximized state across launches.</li>
          <li>Holding Shift while drawing a line or arrow snaps its angle to 15° increments.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.2" date="2026-06-12">
      <description its:translate="no">
        <ul>
          <li>A text annotation's background plate now wraps the text exactly, so the glyphs no longer spill past its edge with some fonts.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.1" date="2026-06-11">
      <description its:translate="no">
        <ul>
          <li>Cursor-anchored zoom now stays pinned under the pointer instead of drifting.</li>
          <li>Resize snaps to whole pixels, so the crop lands exactly on the preview.</li>
          <li>A resize fill now covers only the added margin, not transparent areas of the existing image.</li>
          <li>A fast double-click no longer drops a duplicate stamp or pen dot.</li>
          <li>A text annotation's background plate is included in click and selection bounds.</li>
          <li>The hover aim outline tracks the right annotation after a rotate, delete, or group change.</li>
          <li>Command-line help now documents the FILE argument.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.0" date="2026-06-10">
      <description its:translate="no">
        <ul>
          <li>Editable annotation files (.annoscr): save the canvas and its annotations together, then reopen to keep editing.</li>
          <li>New Undo memory preference bounds the memory kept for canvas rotate/resize undo steps.</li>
          <li>The standalone text editor previews text at the current zoom level.</li>
          <li>Editing and accessibility polish: a keyboard focus ring, a tilted outline on rotated annotations, and a mixed-value marker for multi-selections.</li>
          <li>Translated the paste notifications.</li>
        </ul>
      </description>
    </release>
    <release version="0.9.0" date="2026-06-04">
      <description its:translate="no">
        <p>First public release.</p>
        <ul>
          <li>Annotation tools: pen, text, line, arrow, rectangle, oval, highlighter, and numbered stamps.</li>
          <li>Select, move, duplicate, restack, resize, and freely rotate annotations.</li>
          <li>Rotate the image and resize to crop or expand the canvas.</li>
          <li>Open, paste, drag-and-drop, or capture a screenshot, then export to PNG or JPEG or copy to the clipboard.</li>
          <li>Full keyboard control and screen-reader labelling.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-05-21">
      <description its:translate="no">
        <p>Initial scaffold. Hello-world milestone.</p>
      </description>
    </release>
  </releases>
</component>
